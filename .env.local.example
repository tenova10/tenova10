# ── Supabase ──────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Paystack ───────────────────────────────────────────────
# Get these from: dashboard.paystack.com → Settings → API Keys
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx

# ── Admin ─────────────────────────────────────────────────
# Password for your admin dashboard at /admin
NEXT_PUBLIC_ADMIN_PASSWORD=change_this_to_something_strong

# ── App URL ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
